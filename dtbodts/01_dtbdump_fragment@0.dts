	fragment@0 {
		target = <0xffffffff>;

		__overlay__ {

			pmic@4 {
				#address-cells = <0x1>;
				#interrupt-cells = <0x2>;
				#size-cells = <0x0>;
				compatible = "mediatek,mt6377";
				interrupt-controller;
				interrupts = <0x4>;
				phandle = <0x12>;
				reg = <0x4 0x0>;

				accdet {
					accdet-mic-mode = <0x1>;
					accdet-mic-vol = <0x7>;
					accdet-name = "mt63xx-accdet";
					accdet-plugout-debounce = <0x1>;
					compatible = "mediatek,mt6377-accdet";
					eint_use_ext_res = <0x0>;
					headset-eint-num = <0x0>;
					headset-eint-trig-mode = <0x1>;
					headset-four-key-threshold = <0x0 0x3a 0x79 0xc0 0x190>;
					headset-key-mode = <0x0>;
					headset-mode-setting = <0x500 0x500 0x1 0x1f0 0x800 0x800 0x20 0x44 0x4 0x1 0x5 0x3 0x3 0x5 0xe>;
					headset-three-key-threshold = <0x0 0x50 0xdc 0x190>;
					headset-three-key-threshold-CDD = <0x0 0x79 0xc0 0x258>;
					headset-use-ap-eint = <0x0>;
					io-channel-names = "pmic_accdet";
					io-channels = <0x1 0x9>;
					nvmem = <0x2>;
					nvmem-names = "mt63xx-accdet-efuse";
					phandle = <0x73>;
					status = "okay";
				};

				lbat-service {
					compatible = "mediatek,mt6377-lbat-service";
					phandle = <0x8e>;
				};

				mt6377-auxadc {
					#io-channel-cells = <0x1>;
					compatible = "mediatek,pmic-auxadc", "mediatek,mt6377-auxadc";
					isink_load-supply = <0x3>;
					phandle = <0x1>;

					accdet {
						channel = <0x9>;
					};

					bat-temp {
						channel = <0x3>;
						resistance-ratio = <0x5 0x2>;
					};

					batadc {
						avg-num = <0x80>;
						channel = <0x0>;
						resistance-ratio = <0x7 0x2>;
					};

					chip-temp {
						channel = <0x5>;
					};

					hpofs-cal {
						avg-num = <0x100>;
						channel = <0xc>;
					};

					imix_r {
						channel = <0x10>;
					};

					imp {
						avg-num = <0x80>;
						channel = <0xf>;
						resistance-ratio = <0x7 0x2>;
					};

					vbif {
						channel = <0xe>;
						resistance-ratio = <0x5 0x2>;
					};

					vcdt {
						channel = <0x2>;
					};

					vcore-temp {
						channel = <0x6>;
					};

					vgpu-temp {
						channel = <0x8>;
					};

					vproc-temp {
						channel = <0x7>;
					};
				};

				mt6377-consys {
					compatible = "mediatek,mt6377-consys";
				};

				mt6377-efuse {
					#address-cells = <0x1>;
					#size-cells = <0x1>;
					compatible = "mediatek,mt6377-efuse";
					phandle = <0x2>;

					mt6377_e_data {
						phandle = <0xb>;
						reg = <0x60 0xa>;
					};
				};

				mt6377_clock_buffer {
					clkbuf_ctl = <0xffffffff>;
					compatible = "mediatek,clock_buffer";
					mediatek,dcxo-de-sense-support;
					mediatek,dcxo-impedance-support;
					mediatek,dcxo-spmi-rw;
					mediatek,enable;
					mediatek,pmrc-en-support;
					mediatek,xo-buf-allow-control = <0x0 0x1 0x1 0x1 0x0 0x0 0x1>;
					mediatek,xo-buf-name = "XO_SOC", "XO_WCN", "XO_NFC", "XO_CEL", "RSV1", "RSV2", "XO_EXT";
					mediatek,xo-buf-support = <0x1 0x1 0x1 0x1 0x1 0x1 0x1>;
					mediatek,xo-mode-num = <0x3>;
					mediatek,xo-voter-support;
					phandle = <0x74>;
				};

				mt6377_rtc {
					#address-cells = <0x1>;
					#size-cells = <0x1>;
					base = <0x580>;
					compatible = "mediatek,mt6377-rtc";
					phandle = <0x8f>;
					status = "okay";

					ext_32k {
						bits = <0x6 0x1>;
						phandle = <0x90>;
						reg = <0x2 0x1>;
					};

					fg_init {
						phandle = <0x5>;
						reg = <0x0 0x1>;
					};

					fg_soc {
						phandle = <0x6>;
						reg = <0x1 0x1>;
					};
				};

				mt6377codec {
					compatible = "mediatek,mt6377-sound";
					io-channel-names = "pmic_hpofs_cal";
					io-channels = <0x1 0xc>;
					mediatek,dmic-mode = <0x0>;
					mediatek,mic-type = <0x1 0x1 0x1>;
					nvmem = <0x2>;
					nvmem-names = "pmic-hp-efuse";
					phandle = <0x75>;
					reg-vaud28-supply = <0x4>;
				};

				mt6377keys {
					compatible = "mediatek,mt6377-keys";
					mediatek,long-press-mode = <0x1>;
					phandle = <0x76>;
					power-off-time-sec = <0x3>;

					home {
						linux,keycodes = <0x73>;
					};

					power {
						linux,keycodes = <0x74>;
						wakeup-source;
					};
				};

				mtk-spmi-pmic-debug {
					compatible = "mediatek,spmi-pmic-debug";
				};

				mtk_gauge {
					ACTIVE_TABLE = <0x5>;
					CAR_TUNE_VALUE = <0x62>;
					COM_FG_METER_RESISTANCE = <0x46>;
					COM_R_FG_VALUE = <0x0>;
					CURR_MEASURE_20A = <0x0>;
					DIFFERENCE_FULLOCV_ITH = <0x15e>;
					EMBEDDED_SEL = <0x1>;
					FG_METER_RESISTANCE = <0x46>;
					KEEP_100_PERCENT = <0x1>;
					MULTI_TEMP_GAUGE0 = <0x1>;
					PMIC_MIN_VOL = <0x82dc>;
					PMIC_SHUTDOWN_CURRENT = <0x14>;
					POWERON_SYSTEM_IBOOT = <0x1f4>;
					Q_MAX_SYS_VOLTAGE_BAT0 = <0xd16>;
					Q_MAX_SYS_VOLTAGE_BAT1 = <0xd16>;
					Q_MAX_SYS_VOLTAGE_BAT2 = <0xd16>;
					Q_MAX_SYS_VOLTAGE_BAT3 = <0xd16>;
					RBAT_PULL_UP_VOLT = <0xa8c>;
					R_FG_VALUE = <0x5>;
					SHUTDOWN_1_TIME = <0x3c>;
					SHUTDOWN_GAUGE0_VOLTAGE = <0x84d0>;
					TEMPERATURE_T0 = <0x32>;
					TEMPERATURE_T1 = <0x19>;
					TEMPERATURE_T2 = <0xa>;
					TEMPERATURE_T3 = <0x0>;
					TEMPERATURE_T4 = <0xfffffff6>;
					UNIT_MULTIPLE = <0x1>;
					battery0_profile_t0 = <0x0 0xac6d 0x343 0x1ff 0xab9e 0x344 0x3ff 0xaaf4 0x358 0x5fe 0xaa54 0x358 0x7fe 0xa9bf 0x34d 0x9fd 0xa933 0x357 0xbfd 0xa8a8 0x34c 0xdfc 0xa822 0x34e 0xffb 0xa79f 0x357 0x11fb 0xa71c 0x354 0x13fa 0xa69d 0x358 0x15fa 0xa621 0x358 0x17f9 0xa5a9 0x358 0x19f9 0xa533 0x358 0x1bf8 0xa4c1 0x35b 0x1df8 0xa450 0x362 0x1ff7 0xa3de 0x361 0x21f6 0xa36c 0x35e 0x23f6 0xa2fb 0x35f 0x25f5 0xa28b 0x365 0x27f5 0xa218 0x369 0x29f4 0xa1a5 0x36f 0x2bf4 0xa132 0x371 0x2df3 0xa0bf 0x371 0x2ff2 0xa04f 0x376 0x31f2 0x9fdf 0x379 0x33f1 0x9f6f 0x377 0x35f1 0x9f01 0x37b 0x37f0 0x9e96 0x383 0x39f0 0x9e2c 0x388 0x3bef 0x9dc3 0x389 0x3dee 0x9d5d 0x391 0x3fee 0x9cf9 0x396 0x41ed 0x9c95 0x39e 0x43ed 0x9c35 0x3a2 0x45ec 0x9bd7 0x3ad 0x47ec 0x9b7b 0x3b8 0x49eb 0x9b21 0x3c4 0x4beb 0x9ac7 0x3d0 0x4dea 0x9a6d 0x3e5 0x4fe9 0x9a0a 0x3eb 0x51e9 0x999a 0x3e1 0x53e8 0x9914 0x3c4 0x55e8 0x9881 0x383 0x57e7 0x980b 0x372 0x59e7 0x97ab 0x365 0x5be6 0x975a 0x365 0x5de5 0x970f 0x362 0x5fe5 0x96ca 0x35c 0x61e4 0x968d 0x364 0x63e4 0x964c 0x359 0x65e3 0x9612 0x35c 0x67e3 0x95dc 0x35f 0x69e2 0x95a8 0x365 0x6be1 0x9575 0x366 0x6de1 0x9544 0x36a 0x6fe0 0x9513 0x365 0x71e0 0x94e7 0x367 0x73df 0x94bf 0x374 0x75df 0x9497 0x37d 0x77de 0x9471 0x380 0x79dd 0x944e 0x388 0x7bdd 0x942d 0x38f 0x7ddc 0x940e 0x396 0x7fdc 0x93f0 0x39a 0x81db 0x93d4 0x3a8 0x83db 0x93b9 0x3b5 0x85da 0x9395 0x3b3 0x87da 0x935d 0x390 0x89d9 0x9311 0x364 0x8bd8 0x92c7 0x358 0x8dd8 0x9293 0x360 0x8fd7 0x9268 0x36b 0x91d7 0x923e 0x36f 0x93d6 0x9211 0x369 0x95d6 0x91e9 0x36c 0x97d5 0x91c8 0x375 0x99d4 0x91a8 0x37f 0x9bd4 0x9182 0x387 0x9dd3 0x9154 0x38e 0x9fd3 0x9118 0x38b 0xa1d2 0x90d7 0x381 0xa3d2 0x9099 0x386 0xa5d1 0x9052 0x389 0xa7d0 0x9000 0x36d 0xa9d0 0x8fce 0x36e 0xabcf 0x8fba 0x38f 0xadcf 0x8fa3 0x3b4 0xafce 0x8f81 0x3da 0xb1ce 0x8f3c 0x3ed 0xb3cd 0x8ea1 0x3e6 0xb5cd 0x8d51 0x3e0 0xb7cc 0x8b23 0x3f6 0xb9cb 0x8864 0x41b 0xbbcb 0x851c 0x434 0xbbcb 0x851c 0x434 0xbbcb 0x851c 0x434 0xbbcb 0x851c 0x434 0xbbcb 0x851c 0x434 0xb