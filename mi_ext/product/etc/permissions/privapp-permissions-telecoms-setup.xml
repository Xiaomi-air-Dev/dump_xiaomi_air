<?xml version="1.0" encoding="utf-8"?>
<!-- priv app permission file for setu papp needs to be pushed into /product/etc/permissions/
-->
<permissions>
    <privapp-permissions package="com.trustonic.telecoms.setup">
        <permission name="android.permission.DISPATCH_PROVISIONING_MESSAGE"/>
        <permission name="android.permission.START_ACTIVITIES_FROM_BACKGROUND"/>
        <permission name="android.permission.MASTER_CLEAR"/>
        <permission name="android.permission.READ_PRIVILEGED_PHONE_STATE"/>
        <permission name="android.permission.MODIFY_PHONE_STATE"/>
        <permission name="android.permission.REBOOT"/>
    </privapp-permissions>
</permissions>
