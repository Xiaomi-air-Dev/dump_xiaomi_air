			mcusysoff {
				arm,psci-suspend-param = <0x1010007>;
				compatible = "arm,idle-state";
				entry-latency-us = <0x1c2>;
				exit-latency-us = <0x258>;
				local-timer-stop;
				min-residency-us = <0xfa0>;
				phandle = <0x6>;
			};

			s2idle {
				arm,psci-suspend-param = <0x10180ff>;
				compatible = "arm,idle-state";
				entry-latency-us = <0x2710>;
				exit-latency-us = <0x2710>;
				local-timer-stop;
				min-residency-us = <0xffffffff>;
				phandle = <0xa>;
			};

			system_bus {
				arm,psci-suspend-param = <0x101007f>;
				compatible = "arm,idle-state";
				entry-latency-us = <0x514>;
				exit-latency-us = <0xaf0>;
				local-timer-stop;
				min-residency-us = <0xfa0>;
				phandle = <0x9>;
			};

			system_mem {
				arm,psci-suspend-param = <0x101000f>;
				compatible = "arm,idle-state";
				entry-latency-us = <0x2bc>;
				exit-latency-us = <0x352>;
				local-timer-stop;
				min-residency-us = <0xfa0>;
				phandle = <0x7>;
			};

			system_pll {
				arm,psci-suspend-param = <0x101001f>;
				compatible = "arm,idle-state";
				entry-latency-us = <0x320>;
				exit-latency-us = <0x3b6>;
				local-timer-stop;
				min-residency-us = <0xfa0>;
				phandle = <0x8>;
			};
		};
	};

	disable_unused {
		compatible = "simple-bus";
