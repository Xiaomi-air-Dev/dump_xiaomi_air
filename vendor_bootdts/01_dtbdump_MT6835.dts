		disable-unused-clk-afe {
			clocks = <0x8b 0x0 0x8b 0x1 0x8b 0x2 0x8b 0x3 0x8b 0x4 0x8b 0x5 0x8b 0x6 0x8b 0x7 0x8b 0x8 0x8b 0x9 0x8b 0xa 0x8b 0xb 0x8b 0xc 0x8b 0xd 0x8b 0xe 0x8b 0xf 0x8b 0x10 0x8b 0x11 0x8b 0x12 0x8b 0x13 0x8b 0x14 0x8b 0x15>;
			compatible = "mediatek,clk-disable-unused";
