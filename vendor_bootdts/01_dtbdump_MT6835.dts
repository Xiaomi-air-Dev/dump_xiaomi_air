		cpu@4 {
			capacity-dmips-mhz = <0x17f>;
			compatible = "arm,cortex-a55";
			cpu-idle-states = <0x4 0x5 0x6 0x7 0x8 0x9 0xa>;
			device_type = "cpu";
			enable-method = "psci";
			performance-domains = <0x3 0x0>;
			phandle = <0x11>;
			reg = <0x400>;
		};

		cpu@5 {
			capacity-dmips-mhz = <0x17f>;
			compatible = "arm,cortex-a55";
			cpu-idle-states = <0x4 0x5 0x6 0x7 0x8 0x9 0xa>;
			device_type = "cpu";
			enable-method = "psci";
			performance-domains = <0x3 0x0>;
			phandle = <0x12>;
			reg = <0x500>;
		};

		idle-states {
			entry-method = "arm,psci";

			clusteroff_b {
				arm,psci-suspend-param = <0x1010001>;
				compatible = "arm,idle-state";
				entry-latency-us = <0x64>;
				exit-latency-us = <0xfa>;
				local-timer-stop;
				min-residency-us = <0x76c>;
				phandle = <0xc>;
			};

			clusteroff_l {
				arm,psci-suspend-param = <0x1010001>;
				compatible = "arm,idle-state";
				entry-latency-us = <0x64>;
				exit-latency-us = <0xfa>;
				local-timer-stop;
				min-residency-us = <0x834>;
				phandle = <0x5>;
			};

			cpuoff_b {
				arm,psci-suspend-param = <0x10000>;
				compatible = "arm,idle-state";
				entry-latency-us = <0x32>;
				exit-latency-us = <0x64>;
				local-timer-stop;
				min-residency-us = <0x578>;
				phandle = <0xb>;
