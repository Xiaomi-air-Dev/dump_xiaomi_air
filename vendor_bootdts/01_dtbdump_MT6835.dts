	cpus {
		#address-cells = <0x1>;
		#size-cells = <0x0>;

		cpu-map {

			cluster0 {

				core0 {
					cpu = <0xd>;
				};

				core1 {
					cpu = <0xe>;
				};

				core2 {
					cpu = <0xf>;
				};

				core3 {
					cpu = <0x10>;
				};

				core4 {
					cpu = <0x11>;
				};

				core5 {
					cpu = <0x12>;
				};
			};

			cluster1 {

				core0 {
					cpu = <0x13>;
				};

				core1 {
					cpu = <0x14>;
				};
			};
		};

		cpu@0 {
			capacity-dmips-mhz = <0x17f>;
			compatible = "arm,cortex-a55";
			cpu-idle-states = <0x4 0x5 0x6 0x7 0x8 0x9 0xa>;
			device_type = "cpu";
