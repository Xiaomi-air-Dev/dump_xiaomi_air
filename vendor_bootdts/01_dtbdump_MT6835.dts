		};

		disable-unused-clk-apmixedsys {
			clocks = <0x8a 0x0 0x8a 0x1 0x8a 0x2 0x8a 0x3 0x8a 0x4 0x8a 0x5 0x8a 0x6 0x8a 0x8 0x8a 0x9 0x8a 0xa 0x8a 0xb 0x8a 0xc>;
