		pinctrl {
			#gpio-cells = <0x2>;
			#interrupt-cells = <0x2>;
			compatible = "mediatek,mt6835-pinctrl";
			gpio-controller;
			gpio-ranges = <0x2 0x0 0x0 0xc1>;
			interrupt-controller;
			mediatek,eint = <0x30>;
			phandle = <0x2>;
			reg = <0x0 0x10005000 0x0 0x1000 0x0 0x11b10000 0x0 0x1000 0x0 0x11c40000 0x0 0x1000 0x0 0x11d10000 0x0 0x1000 0x0 0x11d30000 0x0 0x1000 0x0 0x11d40000 0x0 0x1000 0x0 0x11e30000 0x0 0x1000 0x0 0x11eb0000 0x0 0x1000 0x0 0x11ec0000 0x0 0x1000>;
			reg-names = "gpio", "iocfg_lm", "iocfg_rb", "iocfg_bl", "iocfg_bm", "iocfg_br", "iocfg_lt", "iocfg_rm", "iocfg_rt";

			aud_clk_mosi_off {
				phandle = <0x8c>;

				pins_cmd0_dat {
					bias-pull-down;
					input-enable;
					pinmux = <0xa100>;
				};
			};

			aud_clk_mosi_on {
				phandle = <0x8d>;

				pins_cmd0_dat {
					bias-disable;
					input-schmitt-enable;
					pinmux = <0xa101>;
				};
			};

			aud_dat_miso0_off {
				phandle = <0x90>;

				pins_cmd1_dat {
					bias-pull-down;
					input-enable;
					pinmux = <0xa800>;
				};
			};

			aud_dat_miso0_on {
				phandle = <0x91>;

				pins_cmd1_dat {
					bias-disable;
					input-schmitt-enable;
					pinmux = <0xa801>;
				};
			};

			aud_dat_miso1_off {
				phandle = <0x92>;

				pins_cmd1_dat {
					bias-disable;
					input-enable;
					pinmux = <0xa900>;
				};
			};

			aud_dat_miso1_on {
				phandle = <0x93>;

				pins_cmd1_dat {
					bias-disable;
					input-schmitt-enable;
					pinmux = <0xa901>;
				};
			};

			aud_dat_mosi_off {
				phandle = <0x8e>;

				pins_cmd0_dat {
					bias-pull-down;
					input-enable;
					pinmux = <0xa300>;
				};

				pins_cmd1_dat {
					bias-pull-down;
					input-enable;
					pinmux = <0xa400>;
				};
			};

			aud_dat_mosi_on {
				phandle = <0x8f>;

				pins_cmd0_dat {
					bias-disable;
					input-schmitt-enable;
					pinmux = <0xa301>;
				};

				pins_cmd1_dat {
					bias-disable;
					input-schmitt-enable;
					pinmux = <0xa401>;
				};
			};

			aud_gpio_i2s0_off {
				phandle = <0x94>;

				pins_cmd1_dat {
					bias-pull-down;
					input-enable;
					pinmux = <0x2f00>;
				};
			};

			aud_gpio_i2s0_on {
				phandle = <0x95>;

				pins_cmd1_dat {
					bias-disable;
					input-schmitt-enable;
					pinmux = <0x2f03>;
				};
			};

			aud_gpio_i2s3_off {
				phandle = <0x96>;

				pins_cmd1_dat {
					bias-pull-down;
					input-enable;
					pinmux = <0x2c00>;
				};

				pins_cmd2_dat {
					bias-pull-down;
					input-enable;
					pinmux = <0x2d00>;
				};

				pins_cmd3_dat {
					bias-pull-down;
					input-enable;
					pinmux = <0x2e00>;
				};
			};

			aud_gpio_i2s3_on {
				phandle = <0x97>;

				pins_cmd1_dat {
					bias-disable;
					input-schmitt-enable;
					pinmux = <0x2c01>;
				};

				pins_cmd2_dat {
					bias-disable;
					input-schmitt-enable;
					pinmux = <0x2d01>;
				};

				pins_cmd3_dat {
					bias-disable;
					input-schmitt-enable;
					pinmux = <0x2e01>;
				};
			};

			aud_nle_mosi_off {
				phandle = <0xfb>;

				pins_cmd1_dat {
					bias-pull-down;
					input-enable;
					pinmux = <0xa600>;
				};

				pins_cmd2_dat {
					bias-pull-down;
					input-enable;
					pinmux = <0xa700>;
				};
			};

			aud_nle_mosi_on {
				phandle = <0xfc>;

				pins_cmd1_dat {
					bias-disable;
					input-schmitt-enable;
					pinmux = <0xa601>;
				};

				pins_cmd2_dat {
					bias-disable;
					input-schmitt-enable;
					pinmux = <0xa701>;
				};
			};
		};

