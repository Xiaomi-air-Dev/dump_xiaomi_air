			enable-method = "psci";
			performance-domains = <0x3 0x1>;
			phandle = <0x13>;
			reg = <0x600>;
		};

		cpu@101 {
			capacity-dmips-mhz = <0x400>;
			compatible = "arm,cortex-a76";
			cpu-idle-states = <0xb 0xc 0x6 0x7 0x8 0x9 0xa>;
			device_type = "cpu";
			enable-method = "psci";
			performance-domains = <0x3 0x1>;
			phandle = <0x14>;
